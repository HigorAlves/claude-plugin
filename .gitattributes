# Auto detect text files and perform LF normalization
* text=auto

# Markdown files
*.md text eol=lf

# JSON files
*.json text eol=lf

# Shell scripts
*.sh text eol=lf

# Ensure consistent line endings for all text files
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary

# Diff settings for better readability
*.md diff=markdown
*.json diff=json
